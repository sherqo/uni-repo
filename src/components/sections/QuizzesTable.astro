---
interface Quiz {
  date: string;
  details: string | null;
}

interface Props {
  quizzes: Quiz[];
}

const { quizzes } = Astro.props;
---

<section class="space-y-4">
  <h2 class="mt-0 text-2xl font-semibold">Quizzes &amp; Assessments</h2>
  <table class="not-prose w-full border-collapse text-sm">
    <thead>
      <tr class="border-border border-b">
        <th class="text-muted-foreground w-32 py-2 pr-4 text-left font-medium"
          >Date</th
        >
        <th class="text-muted-foreground py-2 text-left font-medium">Details</th
        >
      </tr>
    </thead>
    <tbody>
      {
        quizzes.map((quiz, i) => {
          const isTba = quiz.date === 'TBA' || !quiz.details;
          return (
            <tr class={i < quizzes.length - 1 ? 'border-border border-b' : ''}>
              <td
                class={`py-2 pr-4 font-mono text-xs ${isTba ? 'text-muted-foreground' : 'text-foreground'}`}>
                {quiz.date}
              </td>
              <td class={`py-2 ${isTba ? 'text-muted-foreground' : ''}`}>
                {quiz.details ?? '—'}
              </td>
            </tr>
          );
        })
      }
    </tbody>
  </table>
</section>
