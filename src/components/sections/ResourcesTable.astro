---
interface Link {
  href: string;
  text: string;
}

interface Resource {
  label: string;
  links: Link[];
}

interface Props {
  resources: Resource[];
}

const { resources } = Astro.props;
---

<section class="space-y-4">
  <h2 class="mt-0 text-2xl font-semibold">Links &amp; Resources</h2>
  <table class="not-prose w-full border-collapse text-sm">
    <tbody>
      {
        resources.map((row, i) => (
          <tr class={i < resources.length - 1 ? 'border-border border-b' : ''}>
            <td class="text-muted-foreground w-32 py-2 pr-4">{row.label}</td>
            <td class="py-2">
              {row.links.map((link, j) => (
                <>
                  {j > 0 && <span class="text-muted-foreground mx-1">/</span>}
                  <a
                    href={link.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-primary hover:underline"
                  >
                    {link.text}
                  </a>
                </>
              ))}
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
</section>
