---
import PageLayout from '@/components/layouts/PageLayout.astro';
---

<PageLayout title="About" description="About the CAIE 23P Junior Repo.">
  <header class="my-8">
    <h1 class="mb-1 text-2xl font-bold">About</h1>
  </header>

  <div class="space-y-4 text-sm leading-relaxed">
    <p>
      This is an unofficial, student-maintained repo for the CAIE 23P batch at
      <strong>Ain Shams University – Faculty of Engineering</strong>.
    </p>
    <p>
      We share schedules, recordings, notes, and anything useful to help each other get through the semester.
      Content is voluntary — no guarantees on accuracy or completeness.
    </p>
    <p>
      Maintained by <strong>Sharqawy Wael</strong>.
      Built with <a href="https://astro.build" class="text-primary hover:underline" target="_blank" rel="noopener noreferrer">Astro</a>.
    </p>
    <p>
      Want to add something?
      <a href="mailto:sherqo@sherqo.me" class="text-primary hover:underline">Drop me a message.</a>
    </p>
  </div>
</PageLayout>
