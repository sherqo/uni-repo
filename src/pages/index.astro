---
import PageLayout from '@/components/layouts/PageLayout.astro';
import ResourcesTable from '@/components/sections/ResourcesTable.astro';
import EventsTable from '@/components/sections/EventsTable.astro';
import RecordingsSection from '@/components/sections/RecordingsSection.astro';
import Credits from '@/components/sections/Credits.astro';

import resources from '@/data/resources.json';
import eventsData from '@/data/events.json';
import recordings from '@/data/recordings.json';
import staticContributors from '@/data/credits.json';
import { getContributors } from '@/lib/getContributors';
import { getLastCommitInfo } from '@/lib/getWeekInfo';
import { getHomeEvents } from '@/lib/getHomeEvents';

const lastCommitInfo = await getLastCommitInfo();
const events = await getHomeEvents(eventsData);
---

<PageLayout title="CAIE 23P" description="Voluntary student collaboration hub for CAIE 23P juniors.">
  <header class="mb-4 sm:mb-8">
    <h1 class="mb-1 text-4xl font-bold tracking-tight">CAIE 23P · Junior Repo</h1>
    <p class="text-muted-foreground m-0 text-sm">
      Voluntary student collaboration. May contain mistakes. We're trying to keep things updated as possible.
    </p>
    <p class="text-muted-foreground m-0 mt-1 text-sm">
      Last updated: <strong class="text-foreground">{lastCommitInfo.date}</strong> by
      {
        lastCommitInfo.profile ? (
          <a href={lastCommitInfo.profile} target="_blank" rel="noopener noreferrer" class="text-primary no-underline hover:underline">
            <span>{lastCommitInfo.author}</span>
          </a>
        ) : (
          <span class="inline-flex items-center gap-1">
            {lastCommitInfo.avatar ? (
              <img
                src={lastCommitInfo.avatar}
                alt={`${lastCommitInfo.author} avatar`}
                class="h-[1em] w-[1em] rounded-full align-middle"
                loading="lazy"
                decoding="async"
              />
            ) : null}
            <span class="align-middle">{lastCommitInfo.author}</span>
          </span>
        )
      }
      · We are in
      <strong class="text-foreground">Week <span id="current-week">?</span></strong>
    </p>
    <script is:inline>
      const start = new Date('2026-02-07T00:00:00.000Z');
      const now = new Date();
      const diffMs = now.getTime() - start.getTime();
      const week = diffMs < 0 ? 1 : Math.floor(diffMs / (7 * 24 * 60 * 60 * 1000)) + 1;
      const el = document.getElementById('current-week');
      if (el) el.textContent = String(week);
    </script>
  </header>

  <div class="bg-border my-6 h-px"></div>
  <ResourcesTable id="resources" resources={resources} />

  <div class="bg-border my-6 h-px"></div>
  <EventsTable id="events" events={events} linkText="Need exam dates? See the Exams page." linkHref="/exams" />

  <div class="bg-border my-6 h-px"></div>
  <RecordingsSection id="recordings" courses={recordings} />

  <div class="bg-border my-6 h-px"></div>
  {
    // load live contributors and merge with static list (avoid duplicates)
  }
  <Credits
    id="credits"
    contributors={await getContributors().then(dynamic => {
      // show live contributors first, then all static ones afterwards
      const list: any[] = [];
      dynamic.forEach(d => list.push(d));
      staticContributors.forEach(s => list.push({ ...s, static: true }));
      return list.length ? list : staticContributors;
    })}
  />
</PageLayout>
