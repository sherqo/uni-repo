---
import PageLayout from '@/components/layouts/PageLayout.astro';
import ResourcesTable from '@/components/sections/ResourcesTable.astro';
import QuizzesTable from '@/components/sections/QuizzesTable.astro';
import RecordingsSection from '@/components/sections/RecordingsSection.astro';
import Credits from '@/components/sections/Credits.astro';

import resources from '@/data/resources.json';
import quizzes from '@/data/quizzes.json';
import recordings from '@/data/recordings.json';
import contributors from '@/data/credits.json';
---

<PageLayout
  title="CAIE 23P"
  description="Voluntary student collaboration hub for CAIE 23P juniors.">
  <header class="mb-4 sm:mb-8">
    <h1 class="mb-1 text-4xl font-bold tracking-tight">CAIE 23P · Junior Repo</h1>
    <p class="text-muted-foreground m-0 text-sm">
      Voluntary student collaboration. May contain mistakes. We're trying to keep things updated as
      possible.
    </p>
    <p class="text-muted-foreground m-0 mt-1 text-sm">
      Last updated: <strong class="text-foreground">1 Mar 2026</strong> · We are in
      <strong class="text-foreground">Week 4</strong>
    </p>
  </header>

  <div class="bg-border my-6 h-px"></div>
  <ResourcesTable resources={resources} />

  <div class="bg-border my-6 h-px"></div>
  <QuizzesTable quizzes={quizzes} />

  <div class="bg-border my-6 h-px"></div>
  <RecordingsSection courses={recordings} />

  <div class="bg-border my-6 h-px"></div>
  <Credits contributors={contributors} />
</PageLayout>
